# Supabase project credentials — find these in your Supabase dashboard under
# Project Settings → API
#
# 1. Create a new Supabase project at https://supabase.com
# 2. Run supabase/schema.sql in the SQL editor to create tables
# 3. Run supabase/seed.sql in the SQL editor to load the default data
# 4. Copy this file to .env and fill in the values below
# 5. Add these same variables to your Vercel project environment settings

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
